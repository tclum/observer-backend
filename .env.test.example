# Copy this file to .env.test and fill in your values.
# .env.test is gitignored and never committed.

# ── Airtable (required for globalSetup to fetch real fixtures) ──
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Observations

# ── JWT (must match your deployed or local server's secret) ──
JWT_SECRET=change-me-in-production

# ── E2E test target ──
# Point this at your Vercel preview URL, or http://localhost:3000 for local dev.
# If left blank, E2E tests are skipped automatically.
TEST_API_URL=https://your-preview.vercel.app

# ── E2E test user ──
# Create a dedicated "Active" Observer account in Airtable for tests.
# Never use a real user account here.
TEST_USERNAME=test_observer
TEST_PIN=0000
