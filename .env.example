# ── Airtable credentials ──────────────────────────────────────────────────────
# Required for all API handlers (auth, config, sync, missions)

# Your Airtable Personal Access Token
# Get it from: https://airtable.com/create/tokens
AIRTABLE_TOKEN=your_personal_access_token_here

# The Base ID of your Airtable base (starts with "app")
# Find it in your base URL: https://airtable.com/{BASE_ID}/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# The table name used by /api/sync for observation data
# This is the table where raw spotter observations are written
AIRTABLE_TABLE_NAME=Observations

# ── Airtable table names (used by auth, config, missions) ────────────────────
# These are hardcoded in the handlers but documented here for reference:
#
#   Users       — spotter and admin accounts
#   FieldConfig — observation form config (ages, genders, etc.)
#   Missions    — mission listings and status tracking

# ── Local development ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For tests, these variables are set in beforeEach() inside the test files —
# you do NOT need a .env file to run tests.
